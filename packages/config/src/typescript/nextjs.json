{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./base.json",
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "allowJs": true,
        "jsx": "preserve",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "noEmit": true
    }
}