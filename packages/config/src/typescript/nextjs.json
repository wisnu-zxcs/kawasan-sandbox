{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./base.json",
    "compilerOptions": {
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "node"
        ],
        "jsx": "preserve",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "allowJs": true,
        "noEmit": true,
        "plugins": [
            {
                "name": "next"
            }
        ]
    }
}